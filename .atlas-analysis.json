{
  "projectType": "cli-tool",
  "projectName": "cross",
  "projectDescription": "A zero-setup cross-compilation and cross-testing CLI tool for Rust crates that uses Docker or Podman containers to build and test for any supported target architecture.",
  "theme": "aspen",
  "primaryColor": "#94cb04",
  "lightColor": "#545454",
  "darkColor": null,
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "getting-started",
              "supported-targets"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/overview",
              "configuration/config-file",
              "configuration/environment-variables",
              "configuration/cargo-configuration"
            ]
          },
          {
